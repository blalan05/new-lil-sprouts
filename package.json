{
  "name": "lil-sprouts",
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "build": "node scripts/check-deps.js && prisma generate && vinxi build",
    "check-deps": "node scripts/check-deps.js",
    "start": "vinxi start",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "node scripts/migrate.js deploy",
    "prisma:migrate:status": "node scripts/migrate.js status",
    "postinstall": "prisma generate",
    "test:auth": "node --experimental-strip-types --test tests/auth.test.ts",
    "reset-password": "node --experimental-strip-types scripts/reset-password.js"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.2",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-build": "^7.4.1"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@solidjs/router": "^0.16.1",
    "@solidjs/start": "^1.3.2",
    "@web.awesome.me/webawesome-pro": "3.10.0",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0",
    "solid-js": "^1.9.13",
    "vinxi": "^0.5.11",
    "workbox-window": "^7.4.1"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "magicast": "0.5.1"
      }
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}

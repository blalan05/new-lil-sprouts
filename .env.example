# Required — used to sign session cookies (generate a long random string)
SESSION_SECRET=change-me-to-a-long-random-secret

# Required — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/lilsprouts

# Optional — allow new user registration after the first owner account exists
# ALLOW_REGISTRATION=true

# Optional — production site URL for redirects
# PUBLIC_ORIGIN=https://lilsprouts.io

# Required for install/build — Web Awesome Pro Cloudsmith token
# Without this, pnpm install will skip/fail the private package and `pnpm build` will fail on SSR CSS imports.
# WEBAWESOME_NPM_TOKEN=
